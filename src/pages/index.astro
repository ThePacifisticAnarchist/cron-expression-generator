  <!-- Scrollspy Script for Floating Navigation Scroll Sync -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const sections = [
        document.getElementById('generator-section'),
        document.getElementById('how-to-use'),
        document.getElementById('what-is-cron'),
        document.getElementById('common-examples'),
        document.getElementById('faq-section')
      ].filter(Boolean);
      
      const navLinks = document.querySelectorAll('.floating-nav-link');

      let isScrollingFromClick = false;
      let clickTimeout = null;

      // Handle clicking nav links (set active class instantly, disable scroll listener momentarily)
      navLinks.forEach(link => {
        link.addEventListener('click', () => {
          isScrollingFromClick = true;
          if (clickTimeout) clearTimeout(clickTimeout);
          
          navLinks.forEach(l => {
            if (l === link) {
              l.classList.remove('text-mute');
              l.classList.add('text-white', 'bg-hairline-strong/75', 'border', 'border-hairline-strong');
            } else {
              l.classList.remove('text-white', 'bg-hairline-strong/75', 'border', 'border-hairline-strong');
              l.classList.add('text-mute');
            }
          });

          clickTimeout = setTimeout(() => {
            isScrollingFromClick = false;
          }, 800); // Wait for smooth scroll animation to finish
        });
      });

      // Unified scroll spy calculation
      function updateActiveSectionOnScroll() {
        if (isScrollingFromClick) return;

        let activeSection = null;
        let minDistance = Infinity;

        sections.forEach(sec => {
          const rect = sec.getBoundingClientRect();
          // Offset distance of 150px representing the scroll-mt anchor line
          const distance = Math.abs(rect.top - 150);
          
          // Section must have entered the top half of the screen and not scrolled out completely
          if (rect.top < window.innerHeight * 0.45 && rect.bottom > 150) {
            if (distance < minDistance) {
              minDistance = distance;
              activeSection = sec;
            }
          }
        });

        if (activeSection) {
          const id = activeSection.getAttribute('id');
          navLinks.forEach(link => {
            const href = link.getAttribute('href');
            if (href === `#${id}`) {
              link.classList.remove('text-mute');
              link.classList.add('text-white', 'bg-hairline-strong/75', 'border', 'border-hairline-strong');
            } else {
              link.classList.remove('text-white', 'bg-hairline-strong/75', 'border', 'border-hairline-strong');
              link.classList.add('text-mute');
            }
          });
        }
      }

      // Add optimized scroll listener
      let scrollTicking = false;
      window.addEventListener('scroll', () => {
        if (!scrollTicking) {
          window.requestAnimationFrame(() => {
            updateActiveSectionOnScroll();
            scrollTicking = false;
          });
          scrollTicking = true;
        }
      }, { passive: true });

      // Run initial check
      updateActiveSectionOnScroll();
    });
  </script>

