      <!-- Search Input -->
      <div class="relative w-full sm:w-64">
        <input 
          type="text" 
          id="template-search" 
          placeholder="Search templates..."
          class="w-full bg-canvas-soft-2 border border-hairline hover:border-hairline-strong focus:border-link text-white rounded px-2.5 py-1 text-[11px] font-mono focus:outline-none transition placeholder:text-mute/50"
        />
