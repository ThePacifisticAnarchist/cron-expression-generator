    <!-- Category Filters -->
    <div class="flex flex-wrap gap-1.5" id="template-filters">
      <button type="button" data-filter="all" class="px-2 py-0.5 text-[9px] font-mono font-medium rounded bg-hairline-strong text-white cursor-pointer transition">All</button>
      <button type="button" data-filter="devops" class="px-2 py-0.5 text-[9px] font-mono font-medium rounded text-mute hover:text-white bg-canvas hover:bg-hairline-strong/30 cursor-pointer transition">DevOps</button>
      <button type="button" data-filter="database" class="px-2 py-0.5 text-[9px] font-mono font-medium rounded text-mute hover:text-white bg-canvas hover:bg-hairline-strong/30 cursor-pointer transition">Database</button>
      <button type="button" data-filter="reports" class="px-2 py-0.5 text-[9px] font-mono font-medium rounded text-mute hover:text-white bg-canvas hover:bg-hairline-strong/30 cursor-pointer transition">Reports</button>
    </div>

    <!-- Templates Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="templates-grid">
      <!-- Generated via JS dynamically -->
    </div>
