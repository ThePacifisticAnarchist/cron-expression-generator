    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between border-b border-hairline pb-3 gap-3">
      <div>
        <h3 class="text-[10px] text-mute uppercase font-mono tracking-wider font-bold">Enterprise Templates Library</h3>
        <p class="text-[10px] text-mute font-mono mt-0.5 normal-case">One-click standard configurations for developers</p>
