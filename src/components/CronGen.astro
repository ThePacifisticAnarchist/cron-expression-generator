</div>

<script>
  import { Cron } from 'croner';
  import cronstrue from 'cronstrue';

  // UI state object
  const state = {
    mode: '5', // '5' | '6-seconds' | '6-year' | '7-quartz'
    activeField: 'minute',
    second: { value: '*' },
    minute: { value: '*' },
    hour: { value: '*' },
    day: { value: '*' },
    month: { value: '*' },
    weekday: { value: '*' },
    year: { value: '*' }
  };

  // Setup DOM elements
  const el = {
    // Editable inputs in the main expression box
    exprSecond: document.getElementById('expr-second'),
    exprMinute: document.getElementById('expr-minute'),
    exprHour: document.getElementById('expr-hour'),
    exprDay: document.getElementById('expr-day'),
    exprMonth: document.getElementById('expr-month'),
    exprWeekday: document.getElementById('expr-weekday'),
    exprYear: document.getElementById('expr-year'),

    // Labels
    lblSecond: document.getElementById('lbl-second'),
    lblMinute: document.getElementById('lbl-minute'),
    lblHour: document.getElementById('lbl-hour'),
    lblDay: document.getElementById('lbl-day'),
    lblMonth: document.getElementById('lbl-month'),
    lblWeekday: document.getElementById('lbl-weekday'),
    lblYear: document.getElementById('lbl-year'),

    // Panels
    panelSecond: document.getElementById('panel-second'),
    panelMinute: document.getElementById('panel-minute'),
    panelHour: document.getElementById('panel-hour'),
    panelDay: document.getElementById('panel-day'),
    panelMonth: document.getElementById('panel-month'),
    panelWeekday: document.getElementById('panel-weekday'),
    panelYear: document.getElementById('panel-year'),

    // Grids
    expressionGrid: document.getElementById('expression-grid'),
    labelsGrid: document.getElementById('labels-grid'),

    // Mode switch buttons
    btnMode5: document.getElementById('btn-mode-5'),
    btnMode6Seconds: document.getElementById('btn-mode-6-seconds'),
    btnMode6Year: document.getElementById('btn-mode-6-year'),
    btnMode7Quartz: document.getElementById('btn-mode-7-quartz'),

    // Outputs
    cronOutput: document.getElementById('cron-output'),
    cronDescription: document.getElementById('cron-description'),
    nextRunTime: document.getElementById('next-run-time'),
    nextRunsList: document.getElementById('next-runs-list'),
    copyBtn: document.getElementById('copy-btn'),
    copyToast: document.getElementById('copy-toast'),
  };

  function getActiveFieldsForMode() {
    if (state.mode === '5') {
      return ['minute', 'hour', 'day', 'month', 'weekday'];
    } else if (state.mode === '6-seconds') {
      return ['second', 'minute', 'hour', 'day', 'month', 'weekday'];
    } else if (state.mode === '6-year') {
      return ['minute', 'hour', 'day', 'month', 'weekday', 'year'];
    } else { // '7-quartz'
      return ['second', 'minute', 'hour', 'day', 'month', 'weekday', 'year'];
    }
  }

  function getAllFields() {
    return ['second', 'minute', 'hour', 'day', 'month', 'weekday', 'year'];
  }

  // Active panel selection logic
  function setupActiveFieldListeners() {
    const fields = getAllFields();
    
    fields.forEach(f => {
      const capName = f.charAt(0).toUpperCase() + f.slice(1);
      const exprInput = el[`expr${capName}`];
      const lblBtn = el[`lbl${capName}`];
      
      // Focus on input opens the corresponding presets panel
      if (exprInput) {
        exprInput.addEventListener('focus', () => selectActiveField(f));
        exprInput.addEventListener('click', () => selectActiveField(f));
      }
      
      // Label click triggers panel activation & focuses on input
      if (lblBtn) {
        lblBtn.addEventListener('click', () => {
          selectActiveField(f);
          if (exprInput) {
            exprInput.focus();
            exprInput.select();
          }
        });
      }
    });
  }

  function selectActiveField(fieldName) {
    state.activeField = fieldName;
    
    const fields = getAllFields();
    
    fields.forEach(f => {
      const capName = f.charAt(0).toUpperCase() + f.slice(1);
      const exprInput = el[`expr${capName}`];
      const lblBtn = el[`lbl${capName}`];
      const panel = el[`panel${capName}`];
      
      if (!exprInput || !lblBtn || !panel) return;
      
      if (f === fieldName) {
        // Highlight active expr input
        exprInput.classList.remove('text-white', 'border-transparent');
        exprInput.classList.add('text-link', 'border-link');
        
        // Highlight active label
        lblBtn.classList.remove('text-mute');
        lblBtn.classList.add('text-white', 'font-bold');
        
        // Show panel
        panel.classList.remove('hidden');
      } else {
        // Reset expr input
        exprInput.classList.add('text-white', 'border-transparent');
        exprInput.classList.remove('text-link', 'border-link');
        
        // Reset label
        lblBtn.classList.add('text-mute');
        lblBtn.classList.remove('text-white', 'font-bold');
        
        // Hide panel
        panel.classList.add('hidden');
      }
    });
  }

  // Setup text inputs change listeners
  function setupInputListeners() {
    const fields = getAllFields();
    
    fields.forEach(f => {
      const capName = f.charAt(0).toUpperCase() + f.slice(1);
      const input = el[`expr${capName}`];
      if (input) {
        input.addEventListener('input', () => {
          state[f].value = input.value;
          updateGeneratorFromInputs();
        });
      }
    });
  }

  // Setup preset button listeners
  function setupPresetListeners() {
    const fields = getAllFields();
    
    fields.forEach(f => {
      const capName = f.charAt(0).toUpperCase() + f.slice(1);
      const input = el[`expr${capName}`];
      const presetBtns = document.querySelectorAll(`.preset-btn-${f}`);
      
      presetBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const val = btn.getAttribute('data-val');
          state[f].value = val;
          if (input) {
            input.value = val;
          }
          updateGenerator();
        });
      });
    });
  }

  // Calculate field string based on state
  function getFieldString(fieldName) {
    return state[fieldName].value || '*';
  }

  // Master update loop (pushing values from state to input boxes)
  function updateGenerator() {
    const activeFields = getActiveFieldsForMode();
    activeFields.forEach(f => {
      const capName = f.charAt(0).toUpperCase() + f.slice(1);
      const input = el[`expr${capName}`];
      if (input) {
        input.value = getFieldString(f);
      }
    });
    
    const expression = activeFields.map(getFieldString).join(' ');
    el.cronOutput.value = expression;
    
    updateResults(expression);
  }

  // Input change loop (pulling values from input boxes to state)
  function updateGeneratorFromInputs() {
    const activeFields = getActiveFieldsForMode();
    activeFields.forEach(f => {
      const capName = f.charAt(0).toUpperCase() + f.slice(1);
      const input = el[`expr${capName}`];
      if (input) {
        state[f].value = input.value;
      }
    });
    
    const expression = activeFields.map(getFieldString).join(' ');
    el.cronOutput.value = expression;
    
    updateResults(expression);
  }

  function setMode(mode) {
    if (state.mode === mode) return;
    state.mode = mode;
    
    // 1. Update active tab buttons style
    const modes = ['5', '6-seconds', '6-year', '7-quartz'];
    modes.forEach(m => {
      let btnName = 'btnMode5';
      if (m === '6-seconds') btnName = 'btnMode6Seconds';
      else if (m === '6-year') btnName = 'btnMode6Year';
      else if (m === '7-quartz') btnName = 'btnMode7Quartz';
      
      const btn = el[btnName];
      if (btn) {
        if (m === mode) {
          btn.classList.remove('text-mute', 'hover:text-white');
          btn.classList.add('text-white', 'bg-hairline-strong/60');
          btn.setAttribute('aria-selected', 'true');
        } else {
          btn.classList.remove('text-white', 'bg-hairline-strong/60');
          btn.classList.add('text-mute', 'hover:text-white');
          btn.setAttribute('aria-selected', 'false');
        }
      }
    });
    
    // 2. Update layout grid columns class
    el.expressionGrid.classList.remove('grid-cols-5', 'grid-cols-6', 'grid-cols-7');
    el.labelsGrid.classList.remove('grid-cols-5', 'grid-cols-6', 'grid-cols-7');
    
    if (mode === '5') {
      el.expressionGrid.classList.add('grid-cols-5');
      el.labelsGrid.classList.add('grid-cols-5');
      
      // Hide unused inputs
      el.exprSecond.classList.add('hidden');
      el.exprYear.classList.add('hidden');
      el.lblSecond.classList.add('hidden');
      el.lblYear.classList.add('hidden');
    } else if (mode === '6-seconds') {
      el.expressionGrid.classList.add('grid-cols-6');
      el.labelsGrid.classList.add('grid-cols-6');
      
      el.exprSecond.classList.remove('hidden');
      el.exprYear.classList.add('hidden');
      el.lblSecond.classList.remove('hidden');
      el.lblYear.classList.add('hidden');
    } else if (mode === '6-year') {
      el.expressionGrid.classList.add('grid-cols-6');
      el.labelsGrid.classList.add('grid-cols-6');
      
      el.exprSecond.classList.add('hidden');
      el.exprYear.classList.remove('hidden');
      el.lblSecond.classList.add('hidden');
      el.lblYear.classList.remove('hidden');
    } else { // '7-quartz'
      el.expressionGrid.classList.add('grid-cols-7');
      el.labelsGrid.classList.add('grid-cols-7');
      
      el.exprSecond.classList.remove('hidden');
      el.exprYear.classList.remove('hidden');
      el.lblSecond.classList.remove('hidden');
      el.lblYear.classList.remove('hidden');
    }
    
    // 3. Shift active field focus if current active field is now hidden
    const activeFields = getActiveFieldsForMode();
    if (!activeFields.includes(state.activeField)) {
      selectActiveField(activeFields[0]);
    } else {
      selectActiveField(state.activeField);
    }
    
    // 4. Update generator output
    updateGenerator();
  }

  function setupModeSwitcher() {
    if (el.btnMode5) el.btnMode5.addEventListener('click', () => setMode('5'));
    if (el.btnMode6Seconds) el.btnMode6Seconds.addEventListener('click', () => setMode('6-seconds'));
    if (el.btnMode6Year) el.btnMode6Year.addEventListener('click', () => setMode('6-year'));
    if (el.btnMode7Quartz) el.btnMode7Quartz.addEventListener('click', () => setMode('7-quartz'));
  }

  // Format relative time helper
  function formatRelativeTime(targetDate) {
    const now = new Date();
    const diffMs = targetDate.getTime() - now.getTime();
    const diffSecs = Math.floor(diffMs / 1000);
    const diffMins = Math.floor(diffSecs / 60);
    const diffHours = Math.floor(diffMins / 60);
    const diffDays = Math.floor(diffHours / 24);

    if (diffSecs < 60) {
      return 'in a few seconds';
    } else if (diffMins < 60) {
      return `in ${diffMins}&nbsp;${diffMins === 1 ? 'min' : 'mins'}`;
    } else if (diffHours < 24) {
      return `in ${diffHours}&nbsp;${diffHours === 1 ? 'hr' : 'hrs'}`;
    } else {
      return `in ${diffDays}&nbsp;${diffDays === 1 ? 'day' : 'days'}`;
    }
  }

  // Format date helper for specific timezone
  function formatDateForTz(date, tz) {
    if (tz === 'local') {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, '0');
      const day = String(date.getDate()).padStart(2, '0');
      const hours = String(date.getHours()).padStart(2, '0');
      const minutes = String(date.getMinutes()).padStart(2, '0');
      const seconds = String(date.getSeconds()).padStart(2, '0');
      return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;
    }
    
    try {
      const formatter = new Intl.DateTimeFormat('en-US', {
        timeZone: tz,
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        hour12: false
      });
      
      const parts = formatter.formatToParts(date);
      const valOf = (type) => {
        const found = parts.find(p => p.type === type);
        return found ? found.value : '';
      };
      
      const year = valOf('year');
      const month = valOf('month');
      const day = valOf('day');
      const hour = valOf('hour');
      const minute = valOf('minute');
      const second = valOf('second');
      
      const cleanedHour = hour === '24' ? '00' : hour;
      
      return `${year}-${month}-${day} ${cleanedHour}:${minute}:${second}`;
    } catch (e) {
      console.error('Timezone formatting error', e);
      return date.toISOString().replace('T', ' ').substring(0, 19);
    }
  }

  // Parse and display results
  function updateResults(expression) {
    // 1. Human Readable Description
    try {
      let desc = cronstrue.toString(expression, { use24HourTimeFormat: true });
      if (desc) {
        desc = desc.charAt(0).toUpperCase() + desc.slice(1);
        if (!desc.endsWith('.')) desc += '.';
      }
      el.cronDescription.textContent = `“${desc}”`;
      el.cronDescription.classList.remove('text-rose-500');
      el.cronDescription.classList.add('text-white');
    } catch (e) {
      el.cronDescription.textContent = 'Invalid cron expression.';
      el.cronDescription.classList.remove('text-white');
      el.cronDescription.classList.add('text-rose-500');
      el.nextRunTime.textContent = 'N/A';
      el.nextRunsList.innerHTML = '<li class="text-rose-500 text-center py-2">Invalid schedule expression</li>';
      return;
    }
    
    // 2. Next runs & Dual Timezone display
    try {
      let evalExpression = expression;
      if (state.mode === '6-year') {
        evalExpression = '0 ' + expression; // prepend seconds for croner 7-field evaluation
      }
      
      const cronInstance = new Cron(evalExpression);
      const nextRuns = cronInstance.nextRuns(5);
      
      el.nextRunsList.innerHTML = '';
      
      if (nextRuns.length === 0) {
        el.nextRunTime.textContent = 'N/A';
        el.nextRunsList.innerHTML = '<li class="text-mute text-center py-2">No upcoming occurrences found</li>';
        return;
      }
      
      const topDate = nextRuns[0];
      const tYear = topDate.getFullYear();
      const tMonth = String(topDate.getMonth() + 1).padStart(2, '0');
      const tDay = String(topDate.getDate()).padStart(2, '0');
      const tHours = String(topDate.getHours()).padStart(2, '0');
      const tMinutes = String(topDate.getMinutes()).padStart(2, '0');
      const tSeconds = String(topDate.getSeconds()).padStart(2, '0');
      el.nextRunTime.textContent = `${tYear}-${tMonth}-${tDay} ${tHours}:${tMinutes}:${tSeconds}`;
      
      // Get selected target timezone
      const tzSelect = document.getElementById('tz-select');
      const targetTz = tzSelect ? tzSelect.value : 'UTC';

      nextRuns.forEach((date, index) => {
        const li = document.createElement('li');
        li.className = 'flex flex-col sm:flex-row justify-between items-start sm:items-center py-2 border-b border-hairline last:border-b-0 gap-1.5 sm:gap-2';
        
        const ordinals = ['1st Run', '2nd Run', '3rd Run', '4th Run', '5th Run'];
        
        const localStr = formatDateForTz(date, 'local');
        const targetStr = formatDateForTz(date, targetTz);
        const targetAbbr = date.toLocaleTimeString('en-US', { timeZone: targetTz, timeZoneName: 'short' }).split(' ').pop();
        
        const relativeStr = formatRelativeTime(date);
        
        li.innerHTML = `
          <span class="text-[10px] text-mute uppercase font-semibold shrink-0">${ordinals[index]}</span>
          <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 text-white font-mono text-[10px] sm:text-xs w-full sm:w-auto">
            <span>Local: ${localStr}</span>
            <span class="hidden sm:inline text-mute/30">|</span>
            <span class="text-link font-medium">${targetAbbr}: ${targetStr}</span>
          </div>
          <span class="text-[9px] sm:text-[10px] text-link bg-link/10 px-1.5 py-0.5 rounded border border-link/20 shrink-0 self-end sm:self-auto leading-none">${relativeStr}</span>
        `;
        el.nextRunsList.appendChild(li);
      });

      // Update code snippets dashboard
      updateSnippets(expression);

    } catch (e) {
      el.nextRunTime.textContent = 'Error';
      el.nextRunsList.innerHTML = '<li class="text-rose-500 text-center py-2">Failed to calculate schedule runs</li>';
    }
  }

  // Copy to Clipboard logic
  function setupCopyButton() {
    const copyIcon = document.getElementById('copy-icon');
    const checkIcon = document.getElementById('check-icon');

    el.copyBtn.addEventListener('click', () => {
      const value = el.cronOutput.value;
      if (!value) return;
      
      navigator.clipboard.writeText(value).then(() => {
        showSuccess();
      }).catch(err => {
        el.cronOutput.select();
        try {
          document.execCommand('copy');
          showSuccess();
        } catch (e) {
          console.error('Copy failed', e);
        }
      });
    });

    function showSuccess() {
      if (copyIcon && checkIcon) {
        copyIcon.classList.add('hidden');
        checkIcon.classList.remove('hidden');
      }
      el.copyToast.classList.remove('hidden');
      
      setTimeout(() => {
        if (copyIcon && checkIcon) {
          copyIcon.classList.remove('hidden');
          checkIcon.classList.add('hidden');
        }
        el.copyToast.classList.add('hidden');
      }, 2000);
    }
  }

  // Reverse Parse expression to set UI controls
  function loadCronExpression(expression) {
    if (!expression) return;
    
    const parts = expression.trim().split(/\s+/);
    if (parts.length < 5) return;
    
    let targetMode = '5';
    if (parts.length === 6) {
      const lastPart = parts[5];
      const isYear = /^\d{4}$/.test(lastPart) || 
                     /^\d{4}-\d{4}$/.test(lastPart) || 
                     /^\*$/.test(lastPart) && parts.includes('?');
      const hasFourDigits = /\b\d{4}\b/.test(lastPart);
      const hasQuestionMark = parts.includes('?');
      if (hasFourDigits || hasQuestionMark) {
        targetMode = '6-year';
      } else {
        targetMode = '6-seconds';
      }
    } else if (parts.length >= 7) {
      targetMode = '7-quartz';
    }
    
    setMode(targetMode);
    
    const activeFields = getActiveFieldsForMode();
    activeFields.forEach((f, idx) => {
      const part = parts[idx] || '*';
      state[f].value = part;
      
      const capName = f.charAt(0).toUpperCase() + f.slice(1);
      const input = el[`expr${capName}`];
      if (input) {
        input.value = part;
      }
    });
    
    updateGenerator();
  }

  // Code Snippets generator logic
  const activeTabState = { tab: 'spring' };

  function updateSnippets(expression) {
    const codeBox = document.getElementById('snippet-code-box');
    if (!codeBox) return;

    const parts = expression.trim().split(/\s+/);
    
    let sec = '0', min = '*', hr = '*', dom = '*', mon = '*', dow = '*', yr = '*';
    if (parts.length === 5) {
      [min, hr, dom, mon, dow] = parts;
    } else if (parts.length === 6) {
      if (state.mode === '6-seconds') {
        [sec, min, hr, dom, mon, dow] = parts;
      } else {
        [min, hr, dom, mon, dow, yr] = parts;
      }
    } else if (parts.length >= 7) {
      [sec, min, hr, dom, mon, dow, yr] = parts;
    }

    let codeText = '';
    const tab = activeTabState.tab;

    if (tab === 'spring') {
      codeText = `@Scheduled(cron = "${expression}")\npublic void executeTask() {\n    // Task logic goes here\n}`;
    } else if (tab === 'quartz') {
      codeText = `Trigger trigger = TriggerBuilder.newTrigger()\n    .withIdentity("myTrigger", "group1")\n    .withSchedule(CronScheduleBuilder.cronSchedule("${expression}"))\n    .build();`;
    } else if (tab === 'k8s') {
      let k8sCron = expression;
      let note = '';
      if (parts.length > 5) {
        let fiveParts = [...parts];
        if (state.mode === '6-seconds') {
          fiveParts.shift();
        } else if (state.mode === '6-year') {
          fiveParts.pop();
        } else if (state.mode === '7-quartz') {
          fiveParts.shift();
          fiveParts.pop();
        }
        k8sCron = fiveParts.join(' ');
        note = `# Note: Kubernetes only supports standard 5-field cron. \n# Extracted 5-field equivalent:\n`;
      }
      codeText = `${note}apiVersion: batch/v1\nkind: CronJob\nmetadata:\n  name: my-cron-job\nspec:\n  schedule: "${k8sCron}"\n  jobTemplate:\n    spec:\n      template:\n        spec:\n          containers:\n          - name: worker\n            image: busybox:1.35\n            command: ["/bin/sh", "-c", "echo task complete"]\n          restartPolicy: OnFailure`;
    } else if (tab === 'node') {
      codeText = `const cron = require('node-cron');\n\ncron.schedule('${expression}', () => {\n  console.log('Task executed successfully');\n});`;
    } else if (tab === 'python') {
      codeText = `# Using APScheduler:\nfrom apscheduler.schedulers.blocking import BlockingScheduler\n\nscheduler = BlockingScheduler()\nscheduler.add_job(my_job, 'cron', \n                  second='${sec}', minute='${min}', hour='${hr}', \n                  day='${dom}', month='${mon}', day_of_week='${dow}'${state.mode === '7-quartz' || state.mode === '6-year' ? `, year='${yr}'` : ''})\n\n# Or using Celery Beat:\n# crontab(minute='${min}', hour='${hr}', day_of_week='${dow}', day_of_month='${dom}', month_of_year='${mon}')`;
    }

    codeBox.textContent = codeText;
  }

  // Enterprise templates list
  const templates = [
    {
      name: "Quarterly Database Audit",
      description: "Runs at 03:00 AM on the 1st of January, April, July, and October.",
      expression: "0 3 1 1,4,7,10 *",
      category: "database"
    },
    {
      name: "Hourly Cache Invalidation",
      description: "Runs at minute 0 every hour.",
      expression: "0 * * * *",
      category: "devops"
    },
    {
      name: "Every 10 Seconds Log Rotation",
      description: "High-precision log rotation running every 10 seconds (Quartz/Spring).",
      expression: "*/10 * * * * *",
      category: "devops"
    },
    {
      name: "End of Month Ledger Closure",
      description: "Runs at 23:50 PM on the last day of every month.",
      expression: "50 23 L * ?",
      category: "reports"
    },
    {
      name: "Nightly Database Backup",
      description: "Runs at 02:00 AM every night.",
      expression: "0 2 * * *",
      category: "database"
    },
    {
      name: "Weekly Financial Summary Report",
      description: "Runs at 08:00 AM every Monday.",
      expression: "0 8 * * 1",
      category: "reports"
    },
    {
      name: "AWS EventBridge Schedule (2026-27)",
      description: "Every minute, only during the years 2026-2027.",
      expression: "* * * * ? 2026-2027",
      category: "devops"
    },
    {
      name: "Full Quartz Scheduler Task",
      description: "At second 0, every 15 minutes, Monday through Friday, in year 2026.",
      expression: "0 */15 * * * ? 2026",
      category: "devops"
    },
    {
      name: "Mid-Month Sync System",
      description: "Runs on the nearest weekday to the 15th of every month at midnight.",
      expression: "0 0 15W * ?",
      category: "devops"
    },
    {
      name: "Bi-Weekly Payroll Report",
      description: "Runs at 09:00 AM on the 1st and 15th of the month.",
      expression: "0 9 1,15 * *",
      category: "reports"
    }
  ];

  let activeFilterState = 'all';

  function renderTemplates() {
    const grid = document.getElementById('templates-grid');
    const searchEl = document.getElementById('template-search');
    const searchVal = searchEl ? searchEl.value.toLowerCase() : '';
    
    if (!grid) return;
    
    grid.innerHTML = '';
    
    const filtered = templates.filter(t => {
      const matchCategory = activeFilterState === 'all' || t.category === activeFilterState;
      const matchSearch = t.name.toLowerCase().includes(searchVal) || 
                          t.description.toLowerCase().includes(searchVal) || 
                          t.expression.toLowerCase().includes(searchVal);
      return matchCategory && matchSearch;
    });

    if (filtered.length === 0) {
      grid.innerHTML = '<div class="col-span-1 sm:col-span-2 text-center text-mute py-8 text-xs font-mono">No templates found.</div>';
      return;
    }

    filtered.forEach(t => {
      const card = document.createElement('div');
      card.className = 'bg-canvas-soft-2 border border-hairline hover:border-link/30 rounded-xl p-4 shadow flex flex-col justify-between transition duration-150 group';
      card.innerHTML = `
        <div class="space-y-2">
          <div class="flex items-center justify-between">
            <span class="text-xs font-semibold text-white tracking-tight font-mono">${t.name}</span>
            <span class="text-[9px] text-link bg-link/10 px-1.5 py-0.5 rounded border border-link/20 uppercase font-mono font-bold leading-none">${t.category}</span>
          </div>
          <div class="bg-canvas border border-hairline rounded-lg p-2 text-center font-mono text-[11px] font-bold text-white select-all">
            ${t.expression}
          </div>
          <p class="text-[10px] text-body leading-relaxed">
            ${t.description}
          </p>
        </div>
        <button 
          type="button" 
          class="btn-load-template w-full mt-3 py-1.5 bg-white hover:bg-neutral-200 text-black text-[10px] font-bold rounded transition cursor-pointer text-center"
          data-expr="${t.expression}"
        >
          Load Template
        </button>
      `;
      grid.appendChild(card);
    });

    // Add load button click listeners
    grid.querySelectorAll('.btn-load-template').forEach(btn => {
      btn.addEventListener('click', () => {
        const expr = btn.getAttribute('data-expr');
        if (expr && window['loadCronExpression']) {
          window['loadCronExpression'](expr);
          const generatorSec = document.getElementById('labels-grid');
          if (generatorSec) {
            generatorSec.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }
      });
    });
  }

  // Initialize
  function init() {
    setupInputListeners();
    setupPresetListeners();
    setupActiveFieldListeners();
    setupModeSwitcher();
    setupCopyButton();
    
    // Setup target timezone change listener
    const tzSelect = document.getElementById('tz-select');
    if (tzSelect) {
      tzSelect.addEventListener('change', () => {
        updateGenerator();
      });
    }

    // Setup snippet tabs click listeners
    const tabs = document.querySelectorAll('#snippet-tabs button');
    tabs.forEach(tabBtn => {
      tabBtn.addEventListener('click', () => {
        tabs.forEach(t => {
          t.classList.remove('text-white', 'bg-hairline-strong');
          t.classList.add('text-mute');
          t.setAttribute('aria-selected', 'false');
        });
        tabBtn.classList.remove('text-mute');
        tabBtn.classList.add('text-white', 'bg-hairline-strong');
        tabBtn.setAttribute('aria-selected', 'true');
        
        activeTabState.tab = tabBtn.getAttribute('data-tab') || 'spring';
        updateSnippets(el.cronOutput.value);
      });
    });

    // Setup snippet copy button
    const copySnippetBtn = document.getElementById('btn-copy-snippet');
    const copySnipIcon = document.getElementById('copy-snippet-icon');
    const checkSnipIcon = document.getElementById('check-snippet-icon');
    if (copySnippetBtn) {
      copySnippetBtn.addEventListener('click', () => {
        const codeText = document.getElementById('snippet-code-box')?.textContent;
        if (!codeText) return;
        navigator.clipboard.writeText(codeText).then(() => {
          if (copySnipIcon && checkSnipIcon) {
            copySnipIcon.classList.add('hidden');
            checkSnipIcon.classList.remove('hidden');
            setTimeout(() => {
              copySnipIcon.classList.remove('hidden');
              checkSnipIcon.classList.add('hidden');
            }, 2000);
          }
        });
      });
    }

    // Setup template search and filters
    const tSearch = document.getElementById('template-search');
    if (tSearch) {
      tSearch.addEventListener('input', renderTemplates);
    }
    
    const filterBtns = document.querySelectorAll('#template-filters button');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => {
          b.classList.remove('text-white', 'bg-hairline-strong');
          b.classList.add('text-mute', 'bg-canvas');
        });
        btn.classList.remove('text-mute', 'bg-canvas');
        btn.classList.add('text-white', 'bg-hairline-strong');
        
        activeFilterState = btn.getAttribute('data-filter') || 'all';
        renderTemplates();
      });
    });

    // Set initial values in state
    state.mode = '5';
    state.second.value = '*';
    state.minute.value = '*';
    state.hour.value = '*';
    state.day.value = '*';
    state.month.value = '*';
    state.weekday.value = '*';
    state.year.value = '*';
    
    window['loadCronExpression'] = loadCronExpression;
    
    // Set initial active field representation (Minute)
    selectActiveField('minute');
    
    // Initial templates render
    renderTemplates();

    // Initial run
    updateGenerator();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in {
    animation: fadeIn 0.15s ease-out forwards;
  }
</style>
