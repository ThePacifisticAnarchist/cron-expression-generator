        <button type="button" data-tab="node" class="px-2 py-0.5 text-[9px] font-mono font-medium rounded text-mute hover:text-white transition cursor-pointer" role="tab" aria-selected="false">Node.js</button>
        <button type="button" data-tab="python" class="px-2 py-0.5 text-[9px] font-mono font-medium rounded text-mute hover:text-white transition cursor-pointer" role="tab" aria-selected="false">Python</button>
