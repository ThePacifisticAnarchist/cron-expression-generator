    <div class="relative bg-canvas border border-hairline rounded-lg p-3 overflow-x-auto shadow-inner group">
      <button 
        type="button" 
        id="btn-copy-snippet" 
        class="absolute top-2 right-2 text-mute hover:text-white p-1.5 hover:bg-canvas-soft border border-transparent hover:border-hairline rounded transition cursor-pointer animate-fade-in"
